      "dataset": "",
      "smiles_col": "SMILES",
      "value_col": "LogP",
      "mode": "regression",
      "enabled": true,
      "unit": "logP"
    },
    {
      "key": "pesticide_class",
      "label_ru": "Класс пестицида",
      "prediction_task": "Прогноз по аналогам (класс пестицида)",
      "table": "pesticide_class_dataset",
      "dataset": "",
      "smiles_col": "SMILES",
      "value_col": "Class",
      "mode": "classification",
      "enabled": true,
      "unit": ""
    },
    {
      "key": "toxicity",
      "label_ru": "Генотоксичность",
      "prediction_task": "Прогноз по аналогам (генотоксичность)",
      "table": "toxicity_dataset",
      "dataset": "",
      "smiles_col": "smiles",
      "value_col": "Genotoxicity",
      "mode": "classification",
      "enabled": true,
      "unit": "",
      "value_map": {
        "Positive": "Генотоксичный",
        "Negative": "Не генотоксичный"
